APP_NAME=ScaleCampusLab
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

MFA_CODE_TTL_MINUTES=10
MFA_MAX_ATTEMPTS=5
MFA_RESEND_COOLDOWN_SECONDS=60
MFA_MAX_RESENDS=3

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpaneluser_scalecampuslabs
DB_USERNAME=cpaneluser_scalecampuslabs
DB_PASSWORD=replace_with_cpanel_database_user_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=localhost:8000,127.0.0.1:8000
SANCTUM_TOKEN_EXPIRATION=1440

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

AI_FEATURES_ENABLED=false

VISIT_CHECK_IN_EARLY_MINUTES=240
VISIT_CHECK_IN_LATE_MINUTES=720

WAITLIST_ADMIN_PASSWORD=

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL="${APP_URL}/payments/paystack/callback"
PAYSTACK_SUPPORTED_CURRENCIES=NGN
PAYSTACK_TIMEOUT_SECONDS=15
PAYSTACK_RETRIES=2
PAYSTACK_RETRY_DELAY_MS=250
PAYSTACK_INITIALIZATION_STALE_AFTER_MINUTES=5
