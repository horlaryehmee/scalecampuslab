<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct browser access to Laravel internals when this repo is deployed
    # directly inside public_html and the host cannot point the domain to /public.
    RewriteRule ^(\.env|\.env\..*|artisan|composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|vite\.config\.js|README\.md|CPANEL_DEPLOYMENT\.md)$ - [F,L]
    RewriteRule ^(app|bootstrap|config|database|node_modules|resources|routes|storage|tests|vendor)(/|$) - [F,L]

    # Keep auth headers available for Laravel/Sanctum/API requests.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Send all public web traffic to Laravel's real public directory.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
