APP_NAME=ScaleCampusLab
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

MFA_CODE_TTL_MINUTES=10
MFA_MAX_ATTEMPTS=5
MFA_RESEND_COOLDOWN_SECONDS=60
MFA_MAX_RESENDS=3

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=notice
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpaneluser_scalecampuslabs
DB_USERNAME=cpaneluser_scalecampuslabs
DB_PASSWORD=replace_with_cpanel_database_user_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=your-domain.com,www.your-domain.com
SANCTUM_TOKEN_EXPIRATION=1440

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.your-mail-provider.com
MAIL_PORT=587
MAIL_USERNAME=replace_with_smtp_username
MAIL_PASSWORD=replace_with_smtp_password
MAIL_FROM_ADDRESS="hello@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

AI_FEATURES_ENABLED=false

VISIT_CHECK_IN_EARLY_MINUTES=240
VISIT_CHECK_IN_LATE_MINUTES=720

WAITLIST_ADMIN_PASSWORD=replace_with_a_unique_strong_admin_password

PAYSTACK_PUBLIC_KEY=pk_live_replace_me
PAYSTACK_SECRET_KEY=sk_live_replace_me
PAYSTACK_CALLBACK_URL="${APP_URL}/payments/paystack/callback"
PAYSTACK_SUPPORTED_CURRENCIES=NGN
PAYSTACK_TIMEOUT_SECONDS=15
PAYSTACK_RETRIES=2
PAYSTACK_RETRY_DELAY_MS=250
PAYSTACK_INITIALIZATION_STALE_AFTER_MINUTES=5
